* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: sans-serif;
}

body {
  background: #fff;
  text-align: center;
}

header {
  padding: 30px 20px;
}

h1 {
  font-size: 2rem;
}

p {
  color: #666;
}

.galeria {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
  gap: 10px;
  padding: 20px;
}

.galeria img {
  width: 100%;
  border-radius: 12px;
  opacity: 0;
  transform: translateY(20px);
  transition: 0.6s ease;
}

.galeria img.show {
  opacity: 1;
  transform: translateY(0);
}

.whatsapp {
  display: inline-block;
  margin: 20px;
  padding: 15px 25px;
  background: #25D366;
  color: white;
  text-decoration: none;
  border-radius: 50px;
  font-weight: bold;
}

const imagens = document.querySelectorAll('.galeria img');

function mostrarImagens() {
  imagens.forEach((img, i) => {
    setTimeout(() => {
      img.classList.add('show');
    }, i * 200);
  });
}

